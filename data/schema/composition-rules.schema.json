{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Composition Rules",
  "type": "object",
  "required": ["$schema", "rules"],
  "properties": {
    "$schema": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["left", "right", "relation", "summary"],
        "properties": {
          "left": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "right": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "relation": {
            "type": "string",
            "enum": [
              "composable",
              "conditionally-composable",
              "non-composable",
              "redundant",
              "absorbing",
              "inverse-like",
              "unknown"
            ]
          },
          "summary": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
