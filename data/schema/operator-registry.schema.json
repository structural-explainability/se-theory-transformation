{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Operator Registry",
  "type": "object",
  "required": ["$schema", "operators"],
  "properties": {
    "$schema": { "type": "string" },
    "operators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "family", "summary"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "family": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "summary": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
