{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outcome Registry",
  "type": "object",
  "required": ["$schema", "outcomes"],
  "properties": {
    "$schema": { "type": "string" },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "summary"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z]{3}$"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
