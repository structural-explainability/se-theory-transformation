{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transformation Family Registry",
  "type": "object",
  "required": ["$schema", "families"],
  "properties": {
    "$schema": { "type": "string" },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "summary", "operators"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "operators": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
